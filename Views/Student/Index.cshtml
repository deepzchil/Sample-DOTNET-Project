@model IEnumerable<StudentManagement.Models.Student>

<h2>Students</h2>

<a href="/Student/Create">Add Student</a>

<table border="1">
<tr>
<th>Name</th>
<th>Course</th>
<th>Age</th>
<th>Action</th>
</tr>

@foreach(var item in Model)
{
<tr>
<td>@item.Name</td>
<td>@item.Course</td>
<td>@item.Age</td>
<td>
<a href="/Student/Delete/@item.Id">Delete</a>
</td>
</tr>
}
</table>